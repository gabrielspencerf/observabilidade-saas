# ---------------------------------------------------------------------------
# Stack Swarm / Portainer — template SEM segredos reais
# Copie para: stack.env (local/VPS) e preencha. Não commitar stack.env.
# ---------------------------------------------------------------------------

# Imagem da aplicacao (registry/tag apos build)
APP_IMAGE=observabilidade-saas:v0.3.0

# Dominio publico da aplicacao
APP_HOST=app.exemplo.com
NEXT_PUBLIC_APP_URL=https://app.exemplo.com

# Timezone
TZ=America/Sao_Paulo

# Seguranca (obrigatorios)
POSTGRES_PASSWORD=TROCAR_POSTGRES_PASSWORD_FORTE
SESSION_SECRET=TROCAR_SESSION_SECRET_BEM_LONGO_E_ALEATORIO

# Feature flags (autenticacao)
AUTH_PASSWORD_RESET_ENABLED=false
AUTH_GOOGLE_LOGIN_ENABLED=false
AUTH_REMEMBER_ME_ENABLED=true
NEXT_PUBLIC_AUTH_PASSWORD_RESET_ENABLED=false
NEXT_PUBLIC_AUTH_GOOGLE_LOGIN_ENABLED=false
NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# Sessao e reset
AUTH_DEFAULT_SESSION_TTL_SECONDS=28800
AUTH_REMEMBER_ME_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Criptografia (32 bytes = 64 caracteres hex); obrigatório para seed que grava tokens
CONFIG_ENCRYPTION_KEY=
INTEGRATIONS_ENCRYPTION_KEY=

# OpenAI (opcional; transcrição Whisper e Vision)
OPENAI_API_KEY=

# SMTP (Poste.io)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@exemplo.com
SMTP_PASS=
SMTP_FROM=noreply@exemplo.com
SMTP_REPLY_TO=suporte@exemplo.com

# Compatibilidade (formato estilo Chatwoot/Rails) - opcional
MAILER_SENDER_EMAIL=noreply@exemplo.com <noreply@exemplo.com>
SMTP_DOMAIN=exemplo.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_SSL=false
SMTP_USERNAME=noreply@exemplo.com
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer
MAILER_INBOUND_EMAIL_DOMAIN=exemplo.com

# Google Login (OAuth invite-only)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=
GOOGLE_AUTH_STATE_SECRET=

# Google Ads (opcionais; preencher quando ativar)
GOOGLE_ADS_CONNECT_ENABLED=false
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=
GOOGLE_ADS_ENCRYPTION_KEY=
GOOGLE_ADS_STATE_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Seed: primeiro admin (obrigatorio para app_setup criar o usuario; login em /admin-login)
SEED_ADMIN_PASSWORD=TROCAR_SENHA_SEGURA
SEED_ADMIN_EMAIL=admin@exemplo.com

# Seed opcional de integracoes (Typebot / Evolution)
SEED_TYPEBOT_EXTERNAL_ID=
SEED_TYPEBOT_NAME=
SEED_TYPEBOT_API_TOKEN=
SEED_TYPEBOT_WEBHOOK_SECRET=
SEED_TYPEBOT_METRICS_API_BASE_URL=
SEED_EVOLUTION_EXTERNAL_ID=
SEED_EVOLUTION_INSTANCE_NAME=
SEED_EVOLUTION_BASE_URL=
SEED_EVOLUTION_API_KEY=

# Traefik
TRAEFIK_CERTRESOLVER=letsencryptresolver

# Escala
WEB_REPLICAS=1
WORKER_REPLICAS=1

# Limites de recursos
WEB_CPU_LIMIT=1.0
WEB_MEMORY_LIMIT=1024M
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1024M
POSTGRES_CPU_LIMIT=0.75
POSTGRES_MEMORY_LIMIT=768M
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=512M

# Volumes externos
POSTGRES_VOLUME_NAME=app_postgres_data
REDIS_VOLUME_NAME=app_redis_data

# Backup e snapshot (operacao no VPS)
BACKUP_DIR=/var/backups/observabilidade
BACKUP_RETENTION_DAYS=14
SNAPSHOT_RETENTION_DAYS=7
POSTGRES_SERVICE=observabilidade_postgres
POSTGRES_DB=app
POSTGRES_USER=postgres
