# =============================================================================
# Docker / Portainer (docker-compose.yml)
# =============================================================================
# Usado pelo compose para Postgres e porta da app. Em compose, DATABASE_URL e
# REDIS_URL são montados automaticamente; defina o resto no .env.
# POSTGRES_PASSWORD=postgres
# APP_PORT=3000

# =============================================================================
# Aplicação / Sessão
# =============================================================================

# Banco de dados (PostgreSQL)
# Ex.: postgresql://usuario:senha@localhost:5432/vysen
# No Docker o compose preenche com postgres:5432; use POSTGRES_PASSWORD no .env.
DATABASE_URL=
# Tamanho máximo do pool postgres.js (opcional; padrão 6 dev / 12 prod em src/server/db/index.ts).
# DATABASE_POOL_MAX=12

# Redis (filas do worker: Typebot, Evolution, Google Ads sync)
# Ex.: redis://localhost:6379
REDIS_URL=

# Nome do cookie de sessão (opcional; padrão: session)
SESSION_COOKIE_NAME=session

# Secret para sessão (obrigatório). Use valor longo e aleatório em produção.
SESSION_SECRET=

# Feature flags de autenticação (rollout gradual)
# AUTH_PASSWORD_RESET_ENABLED=true
# AUTH_GOOGLE_LOGIN_ENABLED=true
# AUTH_REMEMBER_ME_ENABLED=true

# Sessão (estratégia "lembrar de mim")
# AUTH_DEFAULT_SESSION_TTL_SECONDS=28800      # 8 horas
# AUTH_REMEMBER_ME_TTL_SECONDS=2592000        # 30 dias
# AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Flags públicas para UI
# NEXT_PUBLIC_AUTH_PASSWORD_RESET_ENABLED=true
# NEXT_PUBLIC_AUTH_GOOGLE_LOGIN_ENABLED=true
# NEXT_PUBLIC_AUTH_REMEMBER_ME_ENABLED=true

# Opcional: URL de ingest para telemetria de depuração (agentDebugLog). Se vazio ou omitido, nada é enviado.
# AGENT_DEBUG_INGEST_URL=

# =============================================================================
# Security rollout flags
# =============================================================================
# Checklist operacional: docs/SECURITY_ACCEPTANCE_CHECKLIST.md
#
# Migrations relacionadas (rodar npm run db:migrate no ambiente):
# - 0016_security_rls_tenant_policies.sql — RLS por tenant_id
# - 0017_tenant_role_permissions.sql — permissões para roles viewer/operator/admin_tenant
#
# Aplicar contexto/policies RLS por request (defesa em profundidade no Postgres).
# PRODUÇÃO: obrigatório SECURITY_ENFORCE_RLS=true (guardrail de startup).
# SECURITY_ENFORCE_RLS=false
# Modo de acesso do worker ao banco durante rollout de RLS:
# - off: comportamento legado (sem contexto RLS dedicado no worker)
# - bypass: worker força app.bypass_rls=on por job (recomendado para primeiro rollout)
# - tenant: usa tenantId quando o job traz tenant; fallback bypass em jobs globais (accountId/connectionId)
# WORKER_DB_ACCESS_MODE=off
# Perfil sugerido para staging inicial de RLS:
# SECURITY_ENFORCE_RLS=true
# WORKER_DB_ACCESS_MODE=bypass
# Exigir token CSRF em mutações autenticadas por cookie (requireAuth + header ou csrf_token em form).
# PRODUÇÃO: obrigatório SECURITY_ENFORCE_CSRF=true (guardrail de startup).
# SECURITY_ENFORCE_CSRF=false
# OAuth (server): whitelist estrita de redirect quando true; omitido = estrito por padrão no código.
# Defina explicitamente SECURITY_STRICT_REDIRECTS=false apenas para rollout gradual (menos restritivo).
# SECURITY_STRICT_REDIRECTS=true
# Permitir fallback plaintext de segredos APENAS em dev local.
# PRODUÇÃO: deve permanecer false (guardrail de startup).
# SECURITY_ALLOW_PLAINTEXT_SECRETS=false
#
# Quantidade de hops de proxy confiáveis para extrair IP em rate limit.
# 0 = ignora X-Forwarded-For e usa somente X-Real-IP.
# RATE_LIMIT_TRUSTED_PROXY_HOPS=1

# Ambiente (development | production)
NODE_ENV=development

# URL base da aplicação (redirects pós-login, OAuth callback, webhooks)
# Ex.: http://localhost:3000  ou  https://seu-dominio.com
# NEXT_PUBLIC_APP_URL=

# Configuração global (setup web): chave para criptografar valores sensíveis na tabela app_global_config.
# Obrigatória apenas se o setup gravar valores sensíveis (ex.: client_secret). 32 bytes: 64 hex ou 44 base64.
# Gerar: openssl rand -hex 32  ou  openssl rand -base64 32
# CONFIG_ENCRYPTION_KEY=
#
# Chave para criptografar segredos de integrações (Evolution/UAZAPI/Typebot API token).
# Se omitida, o sistema usa CONFIG_ENCRYPTION_KEY como fallback.
# INTEGRATIONS_ENCRYPTION_KEY=

# =============================================================================
# Seed Base 1 (apenas para npm run db:seed)
# =============================================================================

# Senha do usuário admin criado pelo seed (obrigatória para rodar o seed)
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_NAME=Super Admin
# SEED_TENANT_NAME=Tenant de Teste
# SEED_TENANT_SLUG=tenant-teste

# Seed opcional: criar bot Typebot e/ou instância Evolution no tenant do seed
# Preencha para gerar registros e obter as URLs de webhook (impressas no log).
# SEED_TYPEBOT_EXTERNAL_ID=          # ID do typebot no Typebot (ex.: typebot-id-abc)
# SEED_TYPEBOT_NAME=                 # Nome exibido (opcional)
# SEED_TYPEBOT_WEBHOOK_SECRET=       # Opcional; se definido, enviar no header X-Webhook-Secret
# SEED_TYPEBOT_API_TOKEN=            # Opcional; token para sincronizacao de metricas Typebot
# SEED_TYPEBOT_METRICS_API_BASE_URL= # Opcional; base da API de metricas (fallback: TYPEBOT_API_BASE_URL)
# SEED_EVOLUTION_EXTERNAL_ID=        # ID da instância no Evolution (ex.: minha-instancia)
# SEED_EVOLUTION_BASE_URL=           # URL base da Evolution API (ex.: https://evolution.exemplo.com)
# SEED_EVOLUTION_INSTANCE_NAME=      # Nome exibido (opcional)
# SEED_EVOLUTION_API_KEY=            # Opcional; API Key da instância Evolution

# =============================================================================
# Google Ads (credenciais globais da aplicação)
# =============================================================================
# OAuth e API: definidas em .env; tokens por conta ficam no banco (criptografados).
# Contas são conectadas pela UI (Dashboard → Google Ads → Conectar).
#
# Autenticação por conta: quando "true", o botão "Conectar nova conta" fica ativo.
# Omitir ou qualquer outro valor deixa o botão desativado com "Conectar nova conta (em breve)".
# GOOGLE_ADS_CONNECT_ENABLED=true

# OAuth 2.0 (Console Cloud Google → APIs & Services → Credentials)
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# URL de redirect (deve estar registrada no console). Se omitida, usa NEXT_PUBLIC_APP_URL + /api/google-ads/auth/callback
# GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/google-ads/auth/callback

# Criptografia dos tokens por conta (32 bytes: 64 caracteres hex ou 44 base64)
# Gerar: openssl rand -hex 32  ou  openssl rand -base64 32
# GOOGLE_ADS_ENCRYPTION_KEY=

# Assinatura do state OAuth (opcional; se omitido, usa SESSION_SECRET)
# GOOGLE_ADS_STATE_SECRET=

# API Google Ads (sync de campanhas e métricas)
# GOOGLE_ADS_DEVELOPER_TOKEN=        # Developer token aprovado (MCC/conta)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=      # Opcional; ID da MCC quando contas são gerenciadas por ela (sem hífens)

# =============================================================================
# Meta Ads (Marketing API + CAPI)
# =============================================================================
# App Meta (developers.facebook.com): OAuth redirect = NEXT_PUBLIC_APP_URL + /api/meta-ads/auth/callback
# META_ADS_CONNECT_ENABLED=true
# META_ADS_APP_ID=
# META_ADS_APP_SECRET=
# META_ADS_REDIRECT_URI=http://localhost:3000/api/meta-ads/auth/callback
# Opcional: versão da Graph API (padrão v21.0)
# META_GRAPH_API_VERSION=v21.0
# Criptografia do token long-lived (32 bytes). Pode reutilizar GOOGLE_ADS_ENCRYPTION_KEY.
# META_ADS_ENCRYPTION_KEY=
# META_ADS_STATE_SECRET=            # Opcional; fallback SESSION_SECRET

# =============================================================================
# Chatwoot (webhook nativo)
# =============================================================================
# Cadastro por tenant em `chatwoot_accounts` (Admin / seed / SQL); nao ha credencial
# global obrigatoria no .env para o MVP. Quando `api_token_encrypted` estiver
# preenchido no registro, o POST /api/webhooks/chatwoot/[accountId] exige o
# header `x-chatwoot-signature` com HMAC-SHA256 do corpo bruto.
# Em NODE_ENV=production o token é obrigatório (fail-closed); em dev pode ficar vazio para testes locais.

# =============================================================================
# WhatsApp Cloud (webhook oficial Meta)
# =============================================================================
# App Secret do app em developers.facebook.com (Settings → Basic → App secret).
# Em staging/produção: obrigatório — valida HMAC-SHA256 (X-Hub-Signature-256) nos POST
# /api/webhooks/whatsapp-cloud/[numberId] e o worker falha na subida se ausente (NODE_ENV=production).
# Lido via env.metaAppSecret em src/config/env.ts.
# Em dev local pode ficar vazio (POST aceita sem assinatura — use só em rede confiável).
# META_APP_SECRET=

# =============================================================================
# Microsoft Clarity (Data Export API)
# =============================================================================
# Token JWT gerado no projeto Clarity (Settings → Data Export). Criptografia: META_ADS_ENCRYPTION_KEY ou GOOGLE_ADS_ENCRYPTION_KEY.
# CLARITY_CONNECT_ENABLED=true

# =============================================================================
# OpenAI (transcrição de áudio em conversas)
# =============================================================================
# Chave da API OpenAI para Whisper (áudio → texto). Usada pelo worker ao processar
# mensagens de áudio recebidas via Evolution. Omitir desativa a transcrição.
# OPENAI_API_KEY=sk-...
#
# Vysen Copilot — roteamento de modelo
# OPENAI_MODEL_THINKING=gpt-5.4-thinking
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_FALLBACK_ENABLED=true
# OPENAI_THINKING_TIMEOUT_MS=30000

# =============================================================================
# PageSpeed Insights (Dashboard → PageSpeed)
# =============================================================================
# API Key do Google (PageSpeed Insights). Crie em Cloud Console → APIs & Services
# → Credentials → Create API Key e habilite a API "PageSpeed Insights API".
# Omitir: o botão de buscar análise na página PageSpeed retorna erro.
# PAGESPEED_API_KEY=

# =============================================================================
# Typebot / Evolution
# =============================================================================
# Não há variáveis obrigatórias por bot/instância: o cadastro é por tenant no banco
# via Admin > Integrações (Typebot, Evolution, UAZAPI) ou seed opcional.
#
# Para métricas Typebot via API, opcionalmente defina base global:
# TYPEBOT_API_BASE_URL=https://api.typebot.io

# =============================================================================
# SMTP (Poste.io ou relay SMTP)
# =============================================================================
# SMTP_ENABLED=true
# SMTP_HOST=mail.creativelane.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=hub@creativelane.io
# SMTP_PASS=
# SMTP_FROM=hub@creativelane.io
# SMTP_REPLY_TO=hub@creativelane.io
#
# Compatibilidade com formato estilo Chatwoot/Rails (opcional):
# MAILER_SENDER_EMAIL=hub@creativelane.io <hub@creativelane.io>
# SMTP_DOMAIN=creativelane.io
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_SSL=false
# SMTP_USERNAME=hub@creativelane.io
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=login
# SMTP_ENABLE_STARTTLS_AUTO=true
# SMTP_OPENSSL_VERIFY_MODE=peer
# MAILER_INBOUND_EMAIL_DOMAIN=exemplo.com

# =============================================================================
# Google Login (OAuth) - invite-only
# =============================================================================
# GOOGLE_AUTH_CLIENT_ID=
# GOOGLE_AUTH_CLIENT_SECRET=
# GOOGLE_AUTH_REDIRECT_URI=
# GOOGLE_AUTH_STATE_SECRET=

# =============================================================================
# Runtime Agno da Vysen (sessao, memoria e workflows)
# =============================================================================
# VYSEN_AGNO_ENABLED=false
# VYSEN_AGNO_SERVICE_URL=http://localhost:9001
# VYSEN_AGNO_SESSION_TABLE=agno_sessions
# VYSEN_AGNO_MEMORY_TABLE=agno_memories

# =============================================================================
# Swarm / Portainer + Traefik (docker-stack.swarm.yml)
# =============================================================================
# Imagem pronta da app (obrigatorio em Swarm; stack nao usa build).
# APP_IMAGE=ghcr.io/gabrielspencerf/observabilidade-saas:latest
#
# Dominio publico da aplicacao (usado na regra do Traefik).
# APP_HOST=app.vysen.com.br
#
# URL publica da app.
# NEXT_PUBLIC_APP_URL=https://app.vysen.com.br
#
# Nome do resolver TLS no Traefik (opcional; default no stack).
# TRAEFIK_CERTRESOLVER=letsencryptresolver
#
# Escala e limites (opcional)
# WEB_REPLICAS=1
# WORKER_REPLICAS=1
# WEB_CPU_LIMIT=1.0
# WEB_MEMORY_LIMIT=1024M
# WORKER_CPU_LIMIT=1.0
# WORKER_MEMORY_LIMIT=1024M
# POSTGRES_CPU_LIMIT=0.75
# POSTGRES_MEMORY_LIMIT=768M
# REDIS_CPU_LIMIT=0.5
# REDIS_MEMORY_LIMIT=512M
#
# Volumes externos (opcional)
# POSTGRES_VOLUME_NAME=app_postgres_data
# REDIS_VOLUME_NAME=app_redis_data
